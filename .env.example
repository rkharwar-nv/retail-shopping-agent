# Copy this file to .env and fill in the three keys.
# .env is gitignored — never commit real keys.

# ─── Role 1: Multimodal input (build.nvidia.com) ───
# Get from: https://build.nvidia.com/  (account + API key tab)
ROLE1_API_KEY=nvapi-REPLACE_ME

# ─── Role 2: Reasoning + tool calling (inference-api.nvidia.com) ───
# Get from: NVIDIA inference-api dashboard
ROLE2_API_KEY=nvapi-REPLACE_ME

# ─── Role 3: Embeddings (inference-api.nvidia.com) ───
# Often the same key as Role 2 (same host). Kept separate so you
# can rotate or scope them independently later.
ROLE3_API_KEY=nvapi-REPLACE_ME
